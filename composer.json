{
    "name": "depa-berlin/sulu-block-swiper",
    "description": "Swiper/Carousel block collection for Sulu CMS",
    "type": "symfony-bundle",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "symfony/framework-bundle": "^7.0",
        "depa-berlin/sulu-block-fragments": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-symfony": "^2.0"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/depa-berlin/sulu-block-fragments"
        }
    ],
    "autoload": {
        "psr-4": {
            "Depa\\SuluBlockSwiperBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Depa\\SuluBlockSwiperBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
